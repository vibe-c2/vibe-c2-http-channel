{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Server",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/http-channel",
      "args": ["--config", ".env"],
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Test All",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/internal/transport/http/httpserver",
      "buildFlags": "-v"
    },
    {
      "name": "Test Current File",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "buildFlags": "-v"
    }
  ]
}
